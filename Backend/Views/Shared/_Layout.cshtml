<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Task Management System</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Backend.styles.css" asp-append-version="true" />
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-deepspace mb-3 sticky-top">
            <div class="container-fluid px-4 px-md-5">
                <a class="navbar-brand navbar-brand-glow" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-sparkles text-white"></i> ✨ Task Management System
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon" style="filter: invert(1)"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link nav-link-glow" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fa-solid fa-chart-line me-1"></i> Dashboard
                            </a>
                        </li>
                    </ul>
                    <div>
                        <a href="http://localhost:4200" class="btn btn-electric" target="_blank">
                            <i class="fa-solid fa-rocket me-1"></i> Open Angular App
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted" style="background: rgba(0,0,0,0.2); backdrop-filter: blur(10px); position: absolute; bottom: 0; width: 100%; border-top: 1px solid rgba(255,255,255,0.05);">
        <div class="container py-3 text-center text-light" style="opacity: 0.6">
            &copy; 2026 - Backend SSR Output - Task Management System
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
